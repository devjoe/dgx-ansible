{{ ansible_managed | comment }}
# Rendered from roles/observability/templates/vmagent-scrape.yml.j2.
# Scrape config for the DGX-side vmagent. Mac vmagent has its own
# config in local-inference/mac/etc/local-inference-vmagent.yml.

global:
  scrape_interval: 15s
  external_labels:
    host: dgx-spark

scrape_configs:
  - job_name: node_exporter
    static_configs:
      - targets:
          - 127.0.0.1:{{ obs_node_exporter_port }}

  - job_name: dcgm_exporter
    static_configs:
      - targets:
          - 127.0.0.1:{{ obs_dcgm_port }}

  # vLLM exposes Prometheus metrics natively on its main port.
  - job_name: vllm
    metrics_path: /metrics
    static_configs:
      - targets:
          - 127.0.0.1:{{ obs_vllm_metrics_port }}

  - job_name: vmagent
    static_configs:
      - targets:
          - 127.0.0.1:{{ obs_vmagent_port }}
